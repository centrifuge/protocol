# rsync filter rules for the public mirror (centrifuge/protocol).
# '-' excludes, '+' includes. First match wins, so '+' rules must come before their parent '-' rule.
# Paths prefixed with '/' are anchored to the repo root.
#
# '-' rules have two uses:
#   1. Exclude private content from being synced to public.
#   2. Preserve public-only files that don't exist in private — excluded paths
#      are never deleted from the destination by rsync, so files committed
#      directly to the public repo (e.g. SECURITY.md, CONTRIBUTING.md) can be
#      protected by adding a '-' rule for them here.

# Tests: exclude private subdirectories
- /test/integration/fork/
- /test/integration/spell/
- /test/integration/env/

# Source: exclude private spell contracts
- /src/spell

# Scripts: keep only FullDeployer, BaseDeployer and their script/ dependencies
+ /script/
+ /script/FullDeployer.s.sol
+ /script/BaseDeployer.s.sol
+ /script/utils/
+ /script/utils/ICreateX.sol
+ /script/utils/CreateX.d.sol
+ /script/utils/CreateXScript.sol
+ /script/utils/JsonRegistry.s.sol
- /script/**

# GitHub Actions: keep only public workflows, exclude everything else
+ /.github/
+ /.github/workflows/
+ /.github/workflows/tests.yml
+ /.github/workflows/fork-tests.yml
- /.github/**
